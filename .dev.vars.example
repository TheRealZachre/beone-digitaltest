# Copy to .dev.vars for local OpenNext/Wrangler preview (do not commit .dev.vars)
NEXTJS_ENV=development

# =============================================================================
# Fastest fix (one command, after wrangler login):
#   npx wrangler login
#   npm run setup:cloudflare
# =============================================================================

# =============================================================================
# GitHub Actions (repo → Settings → Secrets and variables → Actions)
# =============================================================================
# Required:
#   CLOUDFLARE_API_TOKEN
#   CLOUDFLARE_ACCOUNT_ID
# Optional (upload on deploy when set; otherwise keep secrets in Cloudflare dashboard):
#   AUTH_SECRET
#   RESEND_API_KEY
#   AUTH_EMAIL_FROM
#
# Workflow: .github/workflows/deploy-cloudflare.yml
# Uses: npm run ci:cloudflare (OpenNext upload + wrangler promote)
# Does NOT use cloudflare/wrangler-action.
#
# =============================================================================
# Cloudflare Workers Builds — recommended dashboard settings
# =============================================================================
# Option A (simplest): set runtime secret once, keep default deploy command
#   1. Dashboard → digitaltest → Settings → Variables and Secrets
#   2. Add → Secret → AUTH_SECRET = output of: openssl rand -base64 32
#   3. Build command:  npm run build:cloudflare
#   4. Deploy command: npx wrangler deploy
#
# Option B (secret in CI build env):
#   1. Dashboard → digitaltest → Settings → Builds → Build variables and secrets
#   2. Add → Secret → AUTH_SECRET
#   3. Build command:  npm run ci:cloudflare
#   4. Deploy command: echo "deployed in build step"
#
# Do NOT use the manual node_modules stubbing bash build command.

# AUTH_SECRET=
# AUTH_URL=https://your-worker.workers.dev

# Email (Resend) — required for welcome and password-reset emails
# Replace re_xxxxxxxxx with your real API key from https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxx
# AUTH_EMAIL_FROM="BeOne Digital <noreply@yourdomain.com>"

# Analytics app (separate deployment) — required for sidebar links locally
# NEXT_PUBLIC_ANALYTICS_URL=https://analytics-demo-beone.zach-a56.workers.dev
# ANALYTICS_APP_URL=https://analytics-demo-beone.zach-a56.workers.dev

# Optional API keys
# OPENAI_API_KEY=
# TRANSCRIPTION_PROVIDER=openai
